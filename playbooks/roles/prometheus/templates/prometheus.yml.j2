#
# Ansible managed
#
# http://prometheus.io/docs/operating/configuration/

global:
  scrape_interval: 15s
  scrape_timeout: 10s
  evaluation_interval: 15s

  external_labels:
    environment: zdenda-Lenovo-G780

rule_files:
  - /etc/prometheus/rules/*.yml
  - /etc/prometheus/rules/*.yaml
  - /etc/prometheus/rules/*.rules

scrape_configs:
  - job_name: prometheus
    metrics_path: /metrics
    static_configs:
    - targets: {{ prometheus_targets }}
  - job_name: node
    file_sd_configs:
    - files:
      - /etc/prometheus/file_sd/node.yml


scrape_config_files:
  - scrape_configs/*